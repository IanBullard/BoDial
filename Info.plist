<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>BoDial</string>
    <key>CFBundleDisplayName</key>
    <string>BoDial</string>
    <key>CFBundleIdentifier</key>
    <string>com.github.ibullard.bodial</string>
    <key>CFBundleVersion</key>
    <string>0.9.0</string>
    <key>CFBundleShortVersionString</key>
    <string>0.9.0</string>
    <key>CFBundleExecutable</key>
    <string>BoDial</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleIconFile</key>
    <string>BoDial</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <!-- Menu bar only — no Dock icon -->
    <key>LSUIElement</key>
    <true/>

    <!-- TCC usage strings. Shown in the system permission prompts and in
         System Settings. Required or the prompts are generic/unreliable. -->
    <key>NSInputMonitoringUsageDescription</key>
    <string>BoDial reads raw HID reports from the Engineer Bo Scroll Dial to rescale its scroll output.</string>
    <key>NSAccessibilityUsageDescription</key>
    <string>BoDial suppresses the dial's original scroll events so it can inject properly scaled replacements.</string>
</dict>
</plist>
